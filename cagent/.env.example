# Template for ~/.config/cagent/.env  (the REAL file lives there, chmod 600, never committed)
# This is the GLOBAL default account + owner. A persona inherits these unless its config.toml
# names a `mailbox`/`owner` overlay (see the two templates at the bottom of this file).
AGENT_EMAIL=agent@example.com
AGENT_FROM_NAME=cagent
GMAIL_APP_PASSWORD=            # 16-char Google app password (full mailbox access; revocable)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
OWNER_EMAIL=owner@example.com
OWNER_NAME=Owner Name          # owner display name, rendered in the To: header (cosmetic)
STAGING_RECIPIENT=owner+cagent-staging@example.com
COMMAND_TOKEN=                 # shared secret required in email-command subjects
CLAUDE_BIN=$HOME/.local/bin/claude

# --- Per-agent overlays: TWO independent axes selected by non-secret ids in personas/<name>/config.toml ---
# A persona is the cross product of one MAILBOX (sending account) and one OWNER (who it reports to).
# `mailbox = "mailbox-1"` in config.toml loads ~/.config/cagent/.env-mailbox-1; `owner = "owner-2"`
# loads ~/.config/cagent/.env-owner-2. Layering is: .env < .env-<mailbox> < .env-<owner> < .env-<persona>.
# Create each overlay with `umask 077`, chmod 600; ids are filename-safe ([a-z0-9_-], leading alnum).
#
# ~/.config/cagent/.env-mailbox-<id>   (the sending account + transport; holds the only credential)
#   AGENT_EMAIL=agent2@example.com
#   GMAIL_APP_PASSWORD=...        # app password for THAT account
#   IMAP_HOST=imap.gmail.com      # IMAP_PORT/SMTP_HOST/SMTP_PORT optional (inherit the global defaults)
#
# ~/.config/cagent/.env-owner-<id>     (the recipient identity; the command token lives with the owner)
#   OWNER_EMAIL=owner2@example.com
#   OWNER_NAME=Second Owner
#   STAGING_RECIPIENT=owner2+cagent-staging@example.com   # non-LIVE mail goes here
#   COMMAND_TOKEN=...             # authenticates this owner's email commands (!PAUSE / !STOP-SENDING)
